{
  "name": "@freesail/standard-catalog",
  "version": "0.4.5",
  "description": "Freesail Standard UI Component Catalog",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/common/common-utils.d.ts",
      "import": "./dist/common/common-utils.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/schemas",
    "src/common",
    "LICENSE"
  ],
  "scripts": {
    "prepare:catalog": "freesail prepare catalog",
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prebuild": "freesail prepare catalog && freesail validate catalog"
  },
  "keywords": [
    "freesail",
    "catalog",
    "generative-ui",
    "a2ui",
    "react"
  ],
  "peerDependencies": {
    "@freesail/react": "*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@freesail/react": "*",
    "@types/react": "^18.2.0",
    "react": "^18.2.0"
  },
  "dependencies": {
    "react-markdown": "^10.1.0"
  },
  "author": "Thendral AI Ltd",
  "contributors": [
    "Shanmugam Sudalaimuthu"
  ],
  "license": "MIT",
  "freesail": {
    "catalogs": {
      "standard": {
        "catalogId": "https://freesail.dev/catalogs/standard_catalog_v1.json",
        "title": "Freesail Standard Catalog",
        "description": "Unified catalog of standard A2UI components and functions."
      }
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
